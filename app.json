{
  "expo": {
    "name": "Tally",
    "slug": "tally",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/updated-adaptive-icon.png",
    "scheme": "tally",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/icons/updated-adaptive-icon.png",
        "monochromeImage": "./assets/icons/updated-adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yourname.tally",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/updated-splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F5F5"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f89279b6-7c6c-4bb6-bcc6-cd2b029dfaf4"
      }
    },
    "owner": "azhnhakimi",
    "updates": {
      "url": "https://u.expo.dev/f89279b6-7c6c-4bb6-bcc6-cd2b029dfaf4"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
